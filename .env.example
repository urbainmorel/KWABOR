KWABOR_ENVIRONMENT=development

# Generic client values are read only by the matching KWABOR_ENVIRONMENT.
KWABOR_SUPABASE_URL=
KWABOR_SUPABASE_PUBLISHABLE_KEY=

# Optional per-tier values let local validation build several variants safely.
KWABOR_SUPABASE_URL_DEVELOPMENT=
KWABOR_SUPABASE_PUBLISHABLE_KEY_DEVELOPMENT=
KWABOR_SUPABASE_URL_STAGING=
KWABOR_SUPABASE_PUBLISHABLE_KEY_STAGING=
KWABOR_SUPABASE_URL_PRODUCTION=
KWABOR_SUPABASE_PUBLISHABLE_KEY_PRODUCTION=

KWABOR_VERSION_CODE=1
KWABOR_VERSION_NAME=0.1.0

# Production Android signing. The keystore itself remains outside the repository.
KWABOR_ANDROID_KEYSTORE_PATH=
KWABOR_ANDROID_KEYSTORE_PASSWORD=
KWABOR_ANDROID_KEY_ALIAS=
KWABOR_ANDROID_KEY_PASSWORD=

# Injected later by OBS-001. These generated provider files stay unversioned.
KWABOR_FIREBASE_ANDROID_CONFIG_BASE64=
KWABOR_FIREBASE_IOS_CONFIG_BASE64=
